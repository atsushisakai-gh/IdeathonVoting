# Vercel KV環境変数
# Vercelダッシュボードで自動的に設定されます
# ローカル開発で使う場合は、Vercelダッシュボードから値をコピーしてください

# KV_REST_API_URL=your_kv_rest_api_url
# KV_REST_API_TOKEN=your_kv_rest_api_token

# 環境変数が設定されていない場合は、メモリストレージ（開発用）が使われます

# 管理者パスワード（投票データのリセット用）
# 本番環境では必ず変更してください
ADMIN_PASSWORD=admin2025
NEXT_PUBLIC_ADMIN_PASSWORD=admin2025
